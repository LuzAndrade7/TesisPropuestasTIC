{
  "info": {
    "name": "HU07 - Asignar Estudiantes y Solicitar Nueva Aprobación",
    "description": "Endpoints para asignar estudiantes a propuestas (máximo 5) y solicitar nueva aprobación",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "HU07 - PROPUESTAS",
      "item": [
        {
          "name": "HU07 T23 - Solicitar Nueva Aprobación (APROBADA→PENDIENTE)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"motivo\": \"Se han realizado cambios en los estudiantes asignados. Se solicita nueva evaluación.\"\n}"
            },
            "url": {
              "raw": "http://localhost:5000/api/propuestas/{{propuestaId}}/solicitar-nueva-aprobacion",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "propuestas", "{{propuestaId}}", "solicitar-nueva-aprobacion"]
            },
            "description": "HU07 T23: Cambia estado de propuesta APROBADA a PENDIENTE cuando hay cambios en estudiantes"
          },
          "response": []
        }
      ]
    },
    {
      "name": "HU07 - ESTUDIANTES",
      "item": [
        {
          "name": "HU07 T21 - Obtener todos los estudiantes",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:5000/api/estudiantes",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "estudiantes"]
            },
            "description": "HU07 T21: Retorna lista completa de estudiantes disponibles"
          },
          "response": []
        },
        {
          "name": "HU07 T21 - Buscar estudiantes (autocomplete)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:5000/api/estudiantes/buscar?searchTerm=Juan",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "estudiantes", "buscar"],
              "query": [
                {
                  "key": "searchTerm",
                  "value": "Juan"
                }
              ]
            },
            "description": "HU07 T21: Busca estudiantes por nombre, apellido o correo (para autocompletado)"
          },
          "response": []
        },
        {
          "name": "HU07 T21 - Obtener estudiantes disponibles para propuesta",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:5000/api/estudiantes/disponibles/{{propuestaId}}",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "estudiantes", "disponibles", "{{propuestaId}}"]
            },
            "description": "HU07 T21: Retorna estudiantes NO asignados a una propuesta específica"
          },
          "response": []
        },
        {
          "name": "HU07 T20 - Obtener estudiantes asignados a propuesta",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:5000/api/estudiantes/asignados/{{propuestaId}}",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "estudiantes", "asignados", "{{propuestaId}}"]
            },
            "description": "HU07 T20: Retorna lista de estudiantes ya asignados a una propuesta"
          },
          "response": []
        },
        {
          "name": "HU07 T20 - Asignar estudiantes a propuesta (máximo 5)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"estudianteIds\": [1, 2, 3],\n  \"motivo\": \"Asignación inicial de estudiantes para la propuesta\",\n  \"realizadoPor\": \"Profesor@example.com\"\n}"
            },
            "url": {
              "raw": "http://localhost:5000/api/estudiantes/{{propuestaId}}/asignar",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "estudiantes", "{{propuestaId}}", "asignar"]
            },
            "description": "HU07 T20: Asigna 1-5 estudiantes a una propuesta. Si hay cambios desde APROBADA → cambia a PENDIENTE"
          },
          "response": []
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "propuestaId",
      "value": "1",
      "type": "string"
    }
  ]
}
